@page "/convert"
@using System.Xml
@using LPC.Core.Formats
@using LPC.Core.Models
@using LPC.Core.Naming
@inject IJSRuntime JS

<h2>Convert library</h2>

<p class="muted">
    Load a LightBurn <code>.clb</code> library, set source and destination
    profiles, then convert and save. EZCAD2 / EZCAD3 support is scaffolded but
    not yet wired (samples needed).
</p>

<section class="card">
    <h3>1. Choose source file</h3>
    <InputFile OnChange="@OnFilePicked" accept=".clb" />
    @if (sourceLibrary is not null)
    {
        <ul class="meta">
            <li><strong>File:</strong> @sourceFileName</li>
            <li><strong>Display name:</strong> @(string.IsNullOrEmpty(sourceLibrary.DisplayName) ? "(none)" : sourceLibrary.DisplayName)</li>
            <li><strong>Materials:</strong> @sourceLibrary.MaterialCount</li>
            <li><strong>Entries:</strong> @sourceLibrary.EntryCount</li>
        </ul>
    }
</section>

<section class="card">
    <h3>2. Source profile (what the file is today)</h3>
    <div class="grid">
        <label>Laser type
            <select @bind="sourceLaser">
                <option value="@LaserType.Fiber">Fiber</option>
                <option value="@LaserType.Co2">CO2 (lens ignored)</option>
            </select>
        </label>
        <label>Wattage (W)
            <input type="number" min="1" max="10000" @bind="sourceWattage" />
        </label>
        <label>Lens (mm)
            <input type="number" min="1" max="10000" @bind="sourceLens" disabled="@(sourceLaser == LaserType.Co2)" />
        </label>
    </div>
</section>

<section class="card">
    <h3>3. Target profile (what you're converting it to)</h3>
    <div class="grid">
        <label>Laser type
            <select @bind="targetLaser">
                <option value="@LaserType.Fiber">Fiber</option>
                <option value="@LaserType.Co2">CO2 (lens ignored)</option>
            </select>
        </label>
        <label>Max power (cap)
            <input type="number" min="1" max="100" @bind="targetMaxPower" />
        </label>
        <label>Wattage (W)
            <input type="number" min="1" max="10000" @bind="targetWattage" />
        </label>
        <label>Lens (mm)
            <input type="number" min="1" max="10000" @bind="targetLens" disabled="@(targetLaser == LaserType.Co2)" />
        </label>
    </div>
</section>

<section class="card">
    <h3>4. Output</h3>
    <p>
        <strong>Filename:</strong> <code>@OutputFileNamePreview</code><br />
        <strong>Embedded DisplayName:</strong> <code>@OutputDisplayNamePreview</code>
    </p>
    <button class="primary"
            disabled="@(sourceLibrary is null)"
            @onclick="ConvertAndDownload">
        Convert and download
    </button>
    @if (!string.IsNullOrEmpty(status))
    {
        <p class="@statusClass">@status</p>
    }
</section>

@code {
    private const long MaxUploadBytes = 10L * 1024 * 1024; // 10 MB

    private LightBurnLibrary? sourceLibrary;
    private string sourceFileName = string.Empty;

    private LaserType sourceLaser = LaserType.Fiber;
    private int sourceWattage = 30;
    private int sourceLens = 210;

    private LaserType targetLaser = LaserType.Fiber;
    private int targetMaxPower = 100;
    private int targetWattage = 30;
    private int targetLens = 290;

    private string status = string.Empty;
    private string statusClass = "muted";

    private LaserProfile SourceProfile =>
        new(sourceLaser, MaxPower: 100, Lens: sourceLens, Wattage: sourceWattage);

    private LaserProfile TargetProfile =>
        new(targetLaser, MaxPower: targetMaxPower, Lens: targetLens, Wattage: targetWattage);

    private string OutputFileNamePreview =>
        string.IsNullOrEmpty(sourceFileName)
            ? "(pick a source file)"
            : Path.GetFileName(OutputFileName.ForConvertedLibrary(sourceFileName, TargetProfile));

    private string OutputDisplayNamePreview =>
        sourceLibrary is null
            ? "(pick a source file)"
            : OutputFileName.ForDisplayName(sourceLibrary.DisplayName, TargetProfile);

    private async Task OnFilePicked(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            sourceFileName = file.Name;

            await using var stream = file.OpenReadStream(MaxUploadBytes);
            using var reader = new StreamReader(stream);
            var xml = await reader.ReadToEndAsync();
            sourceLibrary = LightBurnLibrary.Parse(xml);

            status = $"Loaded {sourceLibrary.MaterialCount} material(s), {sourceLibrary.EntryCount} entry/entries.";
            statusClass = "ok";
        }
        catch (Exception ex)
        {
            sourceLibrary = null;
            status = $"Failed to load: {ex.Message}";
            statusClass = "error";
        }
    }

    private async Task ConvertAndDownload()
    {
        if (sourceLibrary is null)
        {
            return;
        }

        try
        {
            var converted = sourceLibrary.Convert(SourceProfile, TargetProfile);
            converted.DisplayName = OutputDisplayNamePreview;

            using var ms = new MemoryStream();
            using (var writer = XmlWriter.Create(ms, new XmlWriterSettings
            {
                Indent = true,
                IndentChars = "  ",
                Encoding = System.Text.Encoding.UTF8
            }))
            {
                converted.Document.Save(writer);
            }

            var bytes = ms.ToArray();
            var outName = OutputFileNamePreview;
            await JS.InvokeVoidAsync(
                "lpcDownload",
                outName,
                "application/xml",
                System.Convert.ToBase64String(bytes));

            status = $"Converted and downloaded as {outName} ({bytes.Length:N0} bytes).";
            statusClass = "ok";
        }
        catch (Exception ex)
        {
            status = $"Conversion failed: {ex.Message}";
            statusClass = "error";
        }
    }
}
