@page "/convert"
@rendermode RenderMode.InteractiveServer
@using System.Xml
@using LPC.Core.Formats
@using LPC.Core.Naming
@inject IJSRuntime JS
@inject ConverterState State

<h2>Convert library</h2>

<p class="muted">
    Load a LightBurn <code>.clb</code> library, set source and destination
    profiles, then convert and save (or export as CSV). EZCAD2 / EZCAD3
    support is scaffolded but not yet wired (samples needed).
    Advanced overrides set on the <a href="advanced">Advanced</a> page are
    applied automatically.
</p>

<section class="card">
    <h3>1. Choose source file</h3>
    <InputFile OnChange="@OnFilePicked" accept=".clb" />
    @if (sourceLibrary is not null)
    {
        <ul class="meta">
            <li><strong>File:</strong> @sourceFileName</li>
            <li><strong>Display name:</strong> @(string.IsNullOrEmpty(sourceLibrary.DisplayName) ? "(none)" : sourceLibrary.DisplayName)</li>
            <li><strong>Materials:</strong> @sourceLibrary.MaterialCount</li>
            <li><strong>Entries:</strong> @sourceLibrary.EntryCount</li>
        </ul>
    }
</section>

<section class="card">
    <h3>2. Source profile (what the file is today)</h3>
    <div class="grid">
        <label>Laser type
            <select @bind="State.SourceLaser">
                <option value="@LaserType.Fiber">Fiber</option>
                <option value="@LaserType.Co2">CO2 (lens ignored)</option>
            </select>
        </label>
        <label>Wattage (W)
            <input type="number" min="1" max="10000" @bind="State.SourceWattage" />
        </label>
        <label>Lens (mm)
            <input type="number" min="1" max="10000" @bind="State.SourceLens" disabled="@(State.SourceLaser == LaserType.Co2)" />
        </label>
    </div>
</section>

<section class="card">
    <h3>3. Target profile (what you're converting it to)</h3>
    <div class="grid">
        <label>Laser type
            <select @bind="State.TargetLaser">
                <option value="@LaserType.Fiber">Fiber</option>
                <option value="@LaserType.Co2">CO2 (lens ignored)</option>
            </select>
        </label>
        <label>Max power (cap)
            <input type="number" min="1" max="100" @bind="State.TargetMaxPower" />
        </label>
        <label>Wattage (W)
            <input type="number" min="1" max="10000" @bind="State.TargetWattage" />
        </label>
        <label>Lens (mm)
            <input type="number" min="1" max="10000" @bind="State.TargetLens" disabled="@(State.TargetLaser == LaserType.Co2)" />
        </label>
    </div>
    @if (State.AdvancedOptions.SetPulseWidth)
    {
        <p class="muted">
            Advanced override active: <strong>QPulseWidth = @State.AdvancedOptions.PulseWidth</strong>
            (configured on the <a href="advanced">Advanced</a> page).
        </p>
    }
</section>

<section class="card">
    <h3>4. Output</h3>
    <p>
        <strong>Filename:</strong> <code>@OutputFileNamePreview</code><br />
        <strong>Embedded DisplayName:</strong> <code>@OutputDisplayNamePreview</code>
    </p>
    <div class="button-row">
        <button class="primary"
                disabled="@(sourceLibrary is null)"
                @onclick="ConvertAndDownload">
            Convert and download (.clb)
        </button>
        <button class="secondary"
                disabled="@(sourceLibrary is null)"
                @onclick="ExportCsv">
            Export as CSV
        </button>
    </div>
    @if (!string.IsNullOrEmpty(status))
    {
        <p class="@statusClass">@status</p>
    }
</section>

@code {
    private const long MaxUploadBytes = 10L * 1024 * 1024; // 10 MB

    private LightBurnLibrary? sourceLibrary;
    private string sourceFileName = string.Empty;

    private string status = string.Empty;
    private string statusClass = "muted";

    private string OutputFileNamePreview =>
        string.IsNullOrEmpty(sourceFileName)
            ? "(pick a source file)"
            : Path.GetFileName(OutputFileName.ForConvertedLibrary(sourceFileName, State.TargetProfile));

    private string OutputDisplayNamePreview =>
        sourceLibrary is null
            ? "(pick a source file)"
            : OutputFileName.ForDisplayName(sourceLibrary.DisplayName, State.TargetProfile);

    private async Task OnFilePicked(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            sourceFileName = file.Name;

            await using var stream = file.OpenReadStream(MaxUploadBytes);
            using var reader = new StreamReader(stream);
            var xml = await reader.ReadToEndAsync();
            sourceLibrary = LightBurnLibrary.Parse(xml);

            status = $"Loaded {sourceLibrary.MaterialCount} material(s), {sourceLibrary.EntryCount} entry/entries.";
            statusClass = "ok";
        }
        catch (Exception ex)
        {
            sourceLibrary = null;
            status = $"Failed to load: {ex.Message}";
            statusClass = "error";
        }
    }

    private async Task ConvertAndDownload()
    {
        if (sourceLibrary is null)
        {
            return;
        }

        try
        {
            var converted = sourceLibrary.Convert(
                State.SourceProfile,
                State.TargetProfile,
                State.AdvancedOptions);
            converted.DisplayName = OutputDisplayNamePreview;

            using var ms = new MemoryStream();
            using (var writer = XmlWriter.Create(ms, new XmlWriterSettings
            {
                Indent = true,
                IndentChars = "  ",
                Encoding = System.Text.Encoding.UTF8
            }))
            {
                converted.Document.Save(writer);
            }

            var bytes = ms.ToArray();
            var outName = OutputFileNamePreview;
            await JS.InvokeVoidAsync(
                "lpcDownload",
                outName,
                "application/xml",
                System.Convert.ToBase64String(bytes));

            status = $"Converted and downloaded as {outName} ({bytes.Length:N0} bytes).";
            statusClass = "ok";
        }
        catch (Exception ex)
        {
            status = $"Conversion failed: {ex.Message}";
            statusClass = "error";
        }
    }

    private async Task ExportCsv()
    {
        if (sourceLibrary is null)
        {
            return;
        }

        try
        {
            // Apply the active conversion before CSV export so the values
            // match what would be saved as .clb. The user almost always
            // wants the converted view, not the raw source.
            var converted = sourceLibrary.Convert(
                State.SourceProfile,
                State.TargetProfile,
                State.AdvancedOptions);

            var csv = LightBurnCsvExporter.ToCsv(converted);
            var bytes = System.Text.Encoding.UTF8.GetBytes(csv);

            var stem = Path.GetFileNameWithoutExtension(OutputFileNamePreview);
            var outName = $"{stem}.csv";

            await JS.InvokeVoidAsync(
                "lpcDownload",
                outName,
                "text/csv",
                System.Convert.ToBase64String(bytes));

            status = $"Exported as {outName} ({bytes.Length:N0} bytes).";
            statusClass = "ok";
        }
        catch (Exception ex)
        {
            status = $"CSV export failed: {ex.Message}";
            statusClass = "error";
        }
    }
}
